<UserControl x:Class="InspectionApp.Views.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="{StaticResource NavBarBrush}" Padding="40,24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="INDUSTRIAL INSPECTION SYSTEM"
                               FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Quality Management &amp; Data Entry Platform"
                               FontSize="12" Foreground="#90CAF9" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="DateTimeBlock"
                               FontSize="22" Foreground="#90CAF9" HorizontalAlignment="Right"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Center Content -->
        <Grid Grid.Row="1" Background="Transparent">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Section label -->
                <TextBlock Text="SELECT AN ACTION"
                           FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,36"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="240" Height="180" Margin="0,0,20,0"
                            Tag="create"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="CreatePartType_Click"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="36" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Foreground="White"/>
                            <TextBlock Text="Create Part Type" FontSize="15" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Define inspection parameters" FontSize="11"
                                       Foreground="#90CAF9" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Width="240" Height="180" Margin="20,0,20,0"
                            Tag="productaudit"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Home_Click"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="36" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Foreground="White"/>
                            <TextBlock Text="Product Audit" FontSize="15" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Inspection data entry" FontSize="11"
                                       Foreground="#90CAF9" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Width="240" Height="180" Margin="20,0,0,0"
                            Tag="ppap"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="PPAP_Click"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="36" HorizontalAlignment="Center"
                                       Margin="0,0,0,12" Foreground="White"/>
                            <TextBlock Text="PPAP" FontSize="15" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Production part approval" FontSize="11"
                                       Foreground="#90CAF9" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource NavBarBrush}" Padding="40,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Industrial Inspection System  •  v1.0"
                           FontSize="11" Foreground="#546E7A"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="Powered by .NET 8 WPF"
                           FontSize="11" Foreground="#546E7A" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Settings gear button (bottom-right, floats above content) -->
        <Button x:Name="SettingsBtn" Grid.Row="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,28,28"
                Width="56" Height="56"
                Click="Settings_Click"
                ToolTip="Settings"
                Cursor="Hand"
                BorderThickness="0"
                Background="Transparent">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{StaticResource AccentBrush}"
                            CornerRadius="28" Effect="{StaticResource CardShadow}">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
