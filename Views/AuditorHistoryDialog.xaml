<Window x:Class="InspectionApp.Views.AuditorHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auditor Log"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White">
    <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="3" Padding="24,20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="AUDITOR LOG"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- Table header -->
            <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{StaticResource TableHeaderBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Date / Time"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   Padding="10,10"/>
                        <TextBlock Grid.Column="1" Text="Auditor Name"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   Padding="10,10"/>
                        <TextBlock Grid.Column="2" Text="Context"
                                   Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   Padding="10,10"/>
                    </Grid>

                    <ListView x:Name="HistoryList" Grid.Row="1"
                              BorderThickness="0"
                              SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EBF3FB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" MinHeight="38">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayTime}"
                                                   FontSize="13" Padding="10,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AuditorName}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Padding="10,0" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Context}"
                                                   FontSize="13" Padding="10,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,16,0,0">
                <TextBlock x:Name="CountLabel" DockPanel.Dock="Left"
                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Close" DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="38" Padding="22,0"
                        Click="Close_Click"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
