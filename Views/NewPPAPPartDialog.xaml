<Window x:Class="InspectionApp.Views.NewPPAPPartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Part Number"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="3" Padding="28">
        <StackPanel>

            <TextBlock Text="ADD PART NUMBER"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Part Number"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>

            <TextBox x:Name="PartNumberBox"
                     Height="48" FontSize="18" FontFamily="Segoe UI"
                     Foreground="#1A2332" Background="White"
                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                     Padding="12,0" VerticalContentAlignment="Center"
                     MaxLength="10"
                     PreviewTextInput="PartNumberBox_PreviewTextInput"
                     KeyDown="PartNumberBox_KeyDown"/>

            <TextBlock x:Name="ErrorText"
                       FontSize="13" Foreground="{StaticResource ErrorBrush}"
                       Margin="0,8,0,0" Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Create Part"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="46" Padding="24,0" Margin="0,0,12,0"
                        Click="Create_Click"/>
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="46" Padding="20,0"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
