<Window x:Class="InspectionApp.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="3" Padding="28,22">
        <StackPanel>
            <TextBlock Text="SETTINGS"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- ── BACKGROUND SECTION ─────────────────────── -->
            <TextBlock Text="Background Image"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="CurrentBgLabel"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Transparency:"
                           FontSize="16" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" x:Name="OpacitySlider"
                        Minimum="0" Maximum="1"
                        VerticalAlignment="Center"
                        ValueChanged="OpacitySlider_ValueChanged"/>
                <TextBlock Grid.Column="2" x:Name="OpacityValueLabel"
                           FontSize="16" VerticalAlignment="Center"
                           MinWidth="50" TextAlignment="Right"
                           Margin="10,0,0,0"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Change Background…"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="15" Height="40" Padding="16,6"
                        Click="ChangeBackground_Click"/>
                <Button Content="Remove Background"
                        Style="{StaticResource SecondaryButtonStyle}"
                        FontSize="15" Height="40" Padding="16,6"
                        Margin="10,0,0,0"
                        Click="RemoveBackground_Click"/>
                <Button Content="Open Folder"
                        Style="{StaticResource SecondaryButtonStyle}"
                        FontSize="15" Height="40" Padding="16,6"
                        Margin="10,0,0,0"
                        Click="OpenFolder_Click"
                        ToolTip="Open the Backgrounds folder in Explorer"/>
            </StackPanel>

            <!-- ── AUDITOR LOG ─────────────────────────────── -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Margin="0,18,0,0" Padding="0,14,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="Auditor Log" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="View History"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="15" Height="40" Padding="16,6"
                            Click="AuditorHistory_Click"
                            ToolTip="View timestamped list of all auditor entries"/>
                </DockPanel>
            </Border>

            <!-- ── CLOSE ─────────────────────────────────── -->
            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Margin="0,18,0,0" Padding="0,14,0,0">
                <Button Content="Close" HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        FontSize="15" Height="40" Padding="22,6"
                        Click="Close_Click"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
