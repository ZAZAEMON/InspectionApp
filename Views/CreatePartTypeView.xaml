<UserControl x:Class="InspectionApp.Views.CreatePartTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Create Part Type column-header style.
             Adjust FontSize / Padding here to scale the header row only. -->
        <Style x:Key="ColHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Part Number + Add Parameter row -->
            <RowDefinition Height="*"/>     <!-- Table -->
            <RowDefinition Height="Auto"/>  <!-- Bottom action bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource NavBarBrush}" Padding="28,16">
            <DockPanel>
                <Button DockPanel.Dock="Left" Style="{StaticResource ToolbarButtonStyle}"
                        Click="BackToMenu_Click" Margin="0,0,16,0" ToolTip="Back to Main Menu">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                        <TextBlock Text="Main Menu" Foreground="White"/>
                    </StackPanel>
                </Button>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="CREATE PART TYPE" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Define inspection parameters for a new part" FontSize="11" Foreground="#90CAF9" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ TOOLBAR: Part Number + Add Parameter ═══════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <DockPanel>
                <!-- Part Number with suggestions popup -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,32,0" VerticalAlignment="Center">
                    <TextBlock Text="Part Number:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Grid>
                        <TextBox x:Name="PartNumberBox"
                                 Style="{StaticResource StandardTextBoxStyle}"
                                 Width="240" Height="44"
                                 FontSize="16"
                                 MaxLength="10"
                                 Foreground="#1A2332"
                                 Background="White"
                                 CaretBrush="#1A2332"
                                 GotFocus="PartNumberBox_GotFocus"
                                 LostFocus="PartNumberBox_LostFocus"
                                 MouseEnter="PartNumberBox_MouseEnter"
                                 MouseLeave="PartNumberBox_MouseLeave"
                                 TextChanged="PartNumberBox_LengthGuard"
                                 ToolTip="Hover or click to browse existing parts (max 10 characters)"/>
                        <Popup x:Name="PartSuggestionsPopup"
                               PlacementTarget="{Binding ElementName=PartNumberBox}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               MinWidth="200">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="0,0,5,5"
                                    Effect="{StaticResource CardShadow}">
                                <ListBox x:Name="PartSuggestionsList"
                                         MaxHeight="220"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ItemContainerStyle="{StaticResource PartListItemStyle}"
                                         SelectionChanged="PartSuggestions_SelectionChanged"
                                         LostFocus="PartSuggestionsList_LostFocus"/>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>

                <!-- Right: row count info -->
                <TextBlock x:Name="RowCountLabel" DockPanel.Dock="Right"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- ═══════════ TABLE ═══════════ -->
        <Border Grid.Row="2" Margin="16,12,16,0"
                Background="Transparent"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="6"
                Effect="{StaticResource CardShadow}">
            <DockPanel>

                <!-- Table Column Headers -->
                <Border DockPanel.Dock="Top" Background="{StaticResource TableHeaderBrush}"
                        CornerRadius="5,5,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="S.No"       Style="{StaticResource ColHeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Parameter"  Style="{StaticResource ColHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="Input Type" Style="{StaticResource ColHeaderStyle}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- No rows placeholder -->
                <StackPanel x:Name="EmptyPlaceholder" DockPanel.Dock="Top"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,60">
                    <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                               Foreground="#CFD8DC" HorizontalAlignment="Center"/>
                    <TextBlock Text="No parameters added yet" FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Select a parameter from the dropdown above and click + Add Row"
                               FontSize="12" Foreground="#9E9E9E"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Rows -->
                <ScrollViewer DockPanel.Dock="Top"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ParameterRowsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="rowBorder"
                                        BorderBrush="#E8EAED" BorderThickness="0,0,0,1"
                                        Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Serial # -->
                                        <TextBlock Grid.Column="0" Text="{Binding SerialNumber}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12"/>

                                        <!-- Parameter Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding ParameterName}"
                                                   VerticalAlignment="Center" Padding="8,0"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <!-- Input Type badge -->
                                        <Border Grid.Column="2" Margin="4,8" CornerRadius="12"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Padding="10,4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InputTypeDisplay}" Value="Check">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding InputTypeDisplay}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding InputTypeDisplay}" Value="Check">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                        <Setter TargetName="rowBorder" Property="Background" Value="#FAFBFC"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════ BOTTOM ACTION BAR ═══════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,14">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="  Save Part Type  "
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="36" Click="Save_Click"/>
                <Button DockPanel.Dock="Right" Content="Clear All" Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="36" Click="ClearAll_Click"/>
                <!-- Delete Part: only visible while editing an existing part. -->
                <Button x:Name="DeleteBtn" DockPanel.Dock="Right"
                        Content="Delete Part" Margin="0,0,12,0"
                        Height="36" Padding="18,8"
                        Background="{StaticResource ErrorBrush}" Foreground="White"
                        FontWeight="SemiBold" FontSize="13" Cursor="Hand"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        Click="DeletePart_Click"
                        ToolTip="Permanently delete this part type and its parameters"/>

                <!-- Set Save Path: pick the folder where Submit on the Home screen
                     saves Excel reports. Persists in app_settings.txt next to the EXE. -->
                <Button x:Name="SavePathBtn" DockPanel.Dock="Left"
                        Margin="0,0,12,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="36" Padding="14,6"
                        Click="SetSavePath_Click"
                        ToolTip="Choose the folder where inspection Excel files are saved">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Set Save Path" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock x:Name="CurrentSavePathLabel" DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           FontSize="12" FontStyle="Italic"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="320"/>

                <!-- Status Message -->
                <Border x:Name="StatusBorder" CornerRadius="5" Padding="12,6"
                        Visibility="Collapsed" DockPanel.Dock="Left">
                    <TextBlock x:Name="StatusText" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
        </Border>


    </Grid>
</UserControl>
