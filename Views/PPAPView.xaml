<UserControl x:Class="InspectionApp.Views.PPAPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="PPAPColHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="FontSize"          Value="16"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Padding"           Value="8,12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- V / C toggle pill -->
        <Style x:Key="TypeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width"   Value="44"/>
            <Setter Property="Height"  Value="26"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="ToolTip" Value="C = Check (OK / NOT OK)   |   V = Value (number)"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="13" Background="#E8F5E9">
                            <TextBlock x:Name="lbl" Text="C"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd"  Property="Background" Value="#E3F2FD"/>
                                <Setter TargetName="lbl" Property="Text"       Value="V"/>
                                <Setter TargetName="lbl" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact danger (delete row) -->
        <Style x:Key="RowDeleteStyle" TargetType="Button">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource ErrorBrush}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"  Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="ToolTip" Value="Delete this row"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ErrorLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════ TOOLBAR ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource NavBarBrush}">
            <DockPanel Margin="16,0">

                <!-- Left: Menu | 🔍 icon | Report | + Add Part -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Stretch">

                    <Button Style="{StaticResource ToolbarButtonStyle}" Padding="12,14"
                            Click="BackToMenu_Click" ToolTip="Back to Main Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                            <TextBlock Text="Menu" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="#2A4E7A" Margin="4,10"/>

                    <!-- Search icon only — toggles the parts panel -->
                    <Button x:Name="SearchToggleBtn" Style="{StaticResource ToolbarButtonStyle}"
                            Padding="14,14" Click="SearchToggle_Click"
                            ToolTip="Search existing PPAP parts">
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="16" Foreground="White"/>
                    </Button>

                    <Button x:Name="ReportBtn" Style="{StaticResource ToolbarButtonStyle}"
                            Padding="14,14" Click="Report_Click"
                            ToolTip="Open PPAP inspection reports">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Margin="0,0,8,0" Foreground="White"/>
                            <TextBlock Text="Report" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <!-- + Add Part — opens dialog to create a new PPAP part number -->
                    <Button Style="{StaticResource ToolbarButtonStyle}" Padding="14,14"
                            Click="AddPart_Click" ToolTip="Create a new PPAP part number">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                            <TextBlock Text="Add" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Shift + Auditor.
                     Right margin clears the 138px custom caption buttons (min/max/close)
                     that float over the top-right corner of every hosted view. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,146,0">
                    <TextBlock Text="Shift:" Foreground="#90CAF9" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="ShiftBox"
                              Style="{StaticResource FloatingComboBoxStyle}"
                              Width="110" Height="44"
                              Background="#1A3050" Foreground="White" BorderBrush="#2A4E7A"
                              Padding="10,0" ToolTip="Select shift"
                              WindowChrome.IsHitTestVisibleInChrome="True">
                        <ComboBoxItem Content="G"/>
                        <ComboBoxItem Content="I"/>
                        <ComboBoxItem Content="II"/>
                        <ComboBoxItem Content="III"/>
                    </ComboBox>

                    <Rectangle Width="1" Fill="#2A4E7A" Margin="14,10"/>

                    <TextBlock Text="Auditor:" Foreground="#90CAF9" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="AuditorBox"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Width="220" Height="44"
                             Background="#1A3050" Foreground="White" BorderBrush="#2A4E7A"
                             BorderThickness="1" CaretBrush="White" SelectionBrush="#5C9ED4"
                             Padding="10,6" FontSize="16" VerticalContentAlignment="Center"
                             PreviewTextInput="AuditorBox_PreviewTextInput"
                             WindowChrome.IsHitTestVisibleInChrome="True"
                             ToolTip="Enter auditor / inspector name (alphabets only)"/>
                </StackPanel>

                <!-- Center: loaded part label -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock x:Name="LoadedPartLabel" Text="No PPAP part loaded"
                               FontSize="13" Foreground="#546E7A" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumnDef" Width="0" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Search panel ─── -->
            <Border Grid.Column="0" x:Name="SearchPanel"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Visibility="Collapsed">
                <DockPanel>

                    <Border DockPanel.Dock="Top" Background="{StaticResource NavBarBrush}" Padding="14,10">
                        <TextBlock Text="PPAP PARTS" FontSize="11" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Search TextBox — bare WPF to guarantee text visibility -->
                    <Border DockPanel.Dock="Top" Padding="10,10,10,6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBox x:Name="SearchBox"
                                 Height="36" FontSize="14" FontFamily="Segoe UI"
                                 Foreground="#1A2332" Background="White"
                                 BorderBrush="#CFD8DC" BorderThickness="1"
                                 Padding="10,0" VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Type to filter part numbers"/>
                    </Border>

                    <!-- Part list -->
                    <ListBox x:Name="PartListBox"
                             DockPanel.Dock="Top"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource PartListItemStyle}"
                             MouseDoubleClick="PartListBox_MouseDoubleClick"
                             PreviewKeyDown="PartListBox_PreviewKeyDown"/>
                </DockPanel>
            </Border>

            <!-- Resize grip -->
            <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"
                          Visibility="Collapsed"/>

            <!-- ─── RIGHT: PPAP table ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers: S.No | Parameter | Type | Reading | Del -->
                <Border Grid.Row="0" Background="{StaticResource TableHeaderBrush}" Margin="12,12,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="46"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="S.No"      Style="{StaticResource PPAPColHeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Parameter" Style="{StaticResource PPAPColHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="Type"      Style="{StaticResource PPAPColHeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Reading"   Style="{StaticResource PPAPColHeaderStyle}"/>
                    </Grid>
                </Border>

                <!-- Rows / placeholder -->
                <Grid Grid.Row="1" Margin="12,0,12,12">

                    <!-- Placeholder when no part is loaded -->
                    <StackPanel x:Name="NoPartPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="56" Foreground="#CFD8DC" HorizontalAlignment="Center"/>
                        <TextBlock Text="No PPAP part loaded" FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="Click  +Add  to create a new part, or  🔍  to load an existing one"
                                   FontSize="12" Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Table -->
                    <Border x:Name="TableContainer" Visibility="Collapsed"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}"
                            PreviewGotKeyboardFocus="TableContainer_PreviewGotKeyboardFocus"
                            PreviewKeyDown="TableContainer_PreviewKeyDown">
                        <ScrollViewer x:Name="RowsScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="PPAPRowsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="rowBd"
                                                BorderBrush="#E8EAED" BorderThickness="0,0,0,1"
                                                MinHeight="58" Background="White">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="56"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="220"/>
                                                    <ColumnDefinition Width="46"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- S.No -->
                                                <TextBlock Grid.Column="0" Text="{Binding SerialNumber}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>

                                                <!-- Parameter name (editable, large font) -->
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding ParameterName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource CellTextBoxStyle}"
                                                         Margin="4,6"
                                                         Tag="param"
                                                         ToolTip="Enter parameter name"/>

                                                <!-- Type toggle (C / V) -->
                                                <ToggleButton Grid.Column="2"
                                                              IsChecked="{Binding IsValueType, Mode=TwoWay}"
                                                              Style="{StaticResource TypeToggleStyle}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                                <!-- Reading: TextBox (Value) or ComboBox (Check) -->
                                                <Grid Grid.Column="3" Margin="4,6">
                                                    <TextBox Text="{Binding Reading, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellTextBoxStyle}"
                                                             Visibility="{Binding IsValueType, Converter={StaticResource BoolToVis}}"
                                                             Tag="input"
                                                             PreviewTextInput="NumericInput_PreviewTextInput"/>
                                                    <ComboBox SelectedValue="{Binding Reading, Mode=TwoWay}"
                                                              SelectedValuePath="Content"
                                                              Style="{StaticResource CellComboBoxStyle}"
                                                              Visibility="{Binding IsCheckType, Converter={StaticResource BoolToVis}}"
                                                              Tag="input">
                                                        <ComboBoxItem Content="-Select-"/>
                                                        <ComboBoxItem Content="OK"/>
                                                        <ComboBoxItem Content="NOT OK"/>
                                                        <ComboBoxItem Content="Not Applicable"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Delete row -->
                                                <Button Grid.Column="4"
                                                        Style="{StaticResource RowDeleteStyle}"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Click="DeleteRow_Click">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="13" Foreground="{StaticResource ErrorBrush}"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                <Setter TargetName="rowBd" Property="Background" Value="#FAFBFC"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <DockPanel LastChildFill="False">

                <Border x:Name="StatusBorder" DockPanel.Dock="Left" CornerRadius="4"
                        Padding="10,4" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- Submit — only visible when rows >= 1 -->
                <Button x:Name="SubmitBtn" DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,0" Height="36"
                        Click="Submit_Click"
                        ToolTip="Save PPAP inspection readings to database"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,8,0" Foreground="White"/>
                        <TextBlock Text="Submit" Foreground="White"/>
                    </StackPanel>
                </Button>

                <!-- Add Row — visible when part loaded and rows < 25 -->
                <Button x:Name="AddRowBtn" DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="36" Padding="14,0" Margin="0,0,12,0"
                        Click="AddRow_Click" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="Add Row"/>
                    </StackPanel>
                </Button>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
