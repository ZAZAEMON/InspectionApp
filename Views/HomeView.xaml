<UserControl x:Class="InspectionApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- Inspection table column-header style. -->
        <Style x:Key="InspColHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Main content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════ TOOLBAR ═══════════ -->
        <Border Grid.Row="0" Background="{StaticResource NavBarBrush}">
            <DockPanel Margin="16,0">
                <!-- Left: Nav + Actions -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Stretch">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Padding="12,14"
                            Click="BackToMenu_Click" ToolTip="Back to Main Menu">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" Foreground="White"/>
                            <TextBlock Text="Menu" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="#2A4E7A" Margin="4,10"/>

                    <Button x:Name="SelectPartBtn" Style="{StaticResource ToolbarButtonStyle}" Padding="14,14"
                            Click="SelectPartType_Click" ToolTip="Focus the part loader panel">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" Foreground="White"/>
                            <TextBlock Text="Select Part Type" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ReportBtn" Style="{StaticResource ToolbarButtonStyle}" Padding="14,14"
                            Click="Report_Click" ToolTip="Open past inspection reports"
                            Visibility="Visible">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" Foreground="White"/>
                            <TextBlock Text="Report" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: Shift + Auditor.
                     Right margin clears the 138px custom caption buttons (min/max/close)
                     that float over the top-right corner of every hosted view. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,146,0">
                    <!-- Shift -->
                    <TextBlock Text="Shift:" Foreground="#90CAF9" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="ShiftBox"
                              Style="{StaticResource FloatingComboBoxStyle}"
                              Width="110" Height="44"
                              Background="#1A3050"
                              Foreground="White"
                              BorderBrush="#2A4E7A"
                              Padding="10,0"
                              ToolTip="Select shift"
                              WindowChrome.IsHitTestVisibleInChrome="True">
                        <ComboBoxItem Content="G"/>
                        <ComboBoxItem Content="I"/>
                        <ComboBoxItem Content="II"/>
                        <ComboBoxItem Content="III"/>
                    </ComboBox>

                    <Rectangle Width="1" Fill="#2A4E7A" Margin="14,10"/>

                    <!-- Auditor -->
                    <TextBlock Text="Auditor:" Foreground="#90CAF9" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="AuditorBox"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Width="220" Height="44"
                             Background="#1A3050"
                             Foreground="White"
                             BorderBrush="#2A4E7A"
                             BorderThickness="1"
                             CaretBrush="White"
                             SelectionBrush="#5C9ED4"
                             Padding="10,6"
                             FontSize="16"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="AuditorBox_PreviewTextInput"
                             WindowChrome.IsHitTestVisibleInChrome="True"
                             ToolTip="Enter auditor / inspector name (alphabets only)"/>
                </StackPanel>

                <!-- Center: Part loaded indicator -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock x:Name="LoadedPartLabel"
                               Text="No part loaded" FontSize="12"
                               Foreground="#546E7A" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════ MAIN CONTENT ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumnDef" Width="0" MinWidth="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Part Loader Panel ─── -->
            <Border Grid.Column="0" x:Name="PartLoaderPanel"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Visibility="Collapsed"
                    IsKeyboardFocusWithinChanged="PartLoaderPanel_FocusChanged">
                <DockPanel Margin="0">

                    <!-- Panel Header -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource NavBarBrush}" Padding="14,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="#90CAF9" Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="PART LOADER" FontSize="11" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Search Box -->
                    <Border DockPanel.Dock="Top" Padding="10,10,10,6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBox x:Name="SearchBox"
                                     Style="{StaticResource StandardTextBoxStyle}"
                                     Height="40" FontSize="14"
                                     Foreground="#1A2332"
                                     Background="White"
                                     CaretBrush="#1A2332"
                                     TextChanged="SearchBox_TextChanged"
                                     GotFocus="SearchBox_GotFocus"
                                     ToolTip="Click to show part list, type to filter"/>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="#B0BEC5"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,10,0" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- Load Button -->
                    <Border DockPanel.Dock="Bottom" Padding="10,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Background="{StaticResource BackgroundBrush}">
                        <Button x:Name="LoadBtn" Content="  Load Part  "
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="48" HorizontalAlignment="Stretch"
                                Click="LoadPart_Click"/>
                    </Border>

                    <!-- Part Number List -->
                    <ListBox x:Name="PartListBox"
                             DockPanel.Dock="Top"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="Collapsed"
                             ItemContainerStyle="{StaticResource PartListItemStyle}"
                             SelectionChanged="PartListBox_SelectionChanged"
                             MouseDoubleClick="PartListBox_MouseDoubleClick"
                             PreviewKeyDown="PartListBox_PreviewKeyDown"/>
                </DockPanel>
            </Border>

            <!-- Resize grip -->
            <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeWE"
                          Visibility="Collapsed"/>

            <!-- ─── RIGHT: Inspection Table ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Column Headers (3 columns: S.No | Parameter | Reading) -->
                <Border Grid.Row="0" Background="{StaticResource TableHeaderBrush}"
                        Margin="12,12,12,0">
                    <ScrollViewer x:Name="HeaderScrollViewer"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="350"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="S.No"      Style="{StaticResource InspColHeaderStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Parameter" Style="{StaticResource InspColHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Reading"   Style="{StaticResource InspColHeaderStyle}"/>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <!-- Data rows / placeholder -->
                <Grid Grid.Row="1" Margin="12,0,12,12">

                    <!-- Placeholder shown when no part is loaded -->
                    <StackPanel x:Name="NoPartPlaceholder" VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="56" Foreground="#CFD8DC" HorizontalAlignment="Center"/>
                        <TextBlock Text="No part loaded" FontSize="16"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="Select a part number from the left panel and click Load"
                                   FontSize="12" Foreground="#9E9E9E"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Inspection rows -->
                    <Border x:Name="TableContainer" Visibility="Collapsed"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}"
                            PreviewGotKeyboardFocus="TableContainer_PreviewGotKeyboardFocus">
                        <ScrollViewer x:Name="TableScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      ScrollChanged="TableScrollViewer_ScrollChanged">
                            <ItemsControl x:Name="InspectionRowsControl"
                                          PreviewKeyDown="InspectionArea_PreviewKeyDown">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="rowBd"
                                                BorderBrush="#E8EAED" BorderThickness="0,0,0,1"
                                                MinHeight="56"
                                                Background="White">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="350"/>
                                                    <ColumnDefinition Width="300"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Serial # -->
                                                <TextBlock Grid.Column="0" Text="{Binding SerialNumber}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="16"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>

                                                <!-- Parameter Name -->
                                                <TextBlock Grid.Column="1" Text="{Binding ParameterName}"
                                                           VerticalAlignment="Center" Padding="8,0"
                                                           FontSize="16" FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                                <!-- Reading (single) -->
                                                <Grid Grid.Column="2" Margin="4,4">
                                                    <TextBox Text="{Binding Reading1, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource CellTextBoxStyle}"
                                                             Visibility="{Binding IsValueType, Converter={StaticResource BoolToVis}}"
                                                             Tag="input"
                                                             PreviewTextInput="NumericInput_PreviewTextInput"/>
                                                    <ComboBox SelectedValue="{Binding Reading1, Mode=TwoWay}"
                                                              SelectedValuePath="Content"
                                                              Style="{StaticResource CellComboBoxStyle}"
                                                              Visibility="{Binding IsCheckType, Converter={StaticResource BoolToVis}}"
                                                              Tag="input">
                                                        <ComboBoxItem Content="-Select-"/>
                                                        <ComboBoxItem Content="OK"/>
                                                        <ComboBoxItem Content="NOT OK"/>
                                                        <ComboBoxItem Content="Not Applicable"/>
                                                    </ComboBox>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                <Setter TargetName="rowBd" Property="Background" Value="#FAFBFC"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <DockPanel LastChildFill="False">
                <!-- Left: status message -->
                <Border x:Name="StatusBorder" DockPanel.Dock="Left" CornerRadius="4"
                        Padding="10,4" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold"/>
                </Border>

                <!-- Far right: Submit button -->
                <Button x:Name="SubmitBtn" DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="20,0" Height="36"
                        Click="Submit_Click"
                        ToolTip="Save inspection readings to database"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE78C;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,8,0" Foreground="White"/>
                        <TextBlock x:Name="SubmitBtnLabel" Text="Submit" Foreground="White"/>
                    </StackPanel>
                </Button>

                <!-- Right of status, left of Submit: saved file path -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock x:Name="FilePathPrefix" Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBox x:Name="FilePathBox"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="11"
                             Foreground="{StaticResource AccentBrush}"
                             VerticalAlignment="Center"
                             Cursor="IBeam"
                             IsReadOnlyCaretVisible="True"
                             ToolTip="Click to select and copy the file path"
                             Visibility="Collapsed"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
