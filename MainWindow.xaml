<Window x:Class="InspectionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Industrial Inspection System"
        Icon="app.ico"
        Height="780" Width="1320"
        MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1A3050"
        FontFamily="Segoe UI">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="4"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <!-- Solid base color -->
        <Rectangle Fill="{StaticResource BackgroundBrush}"/>

        <!-- Background image -->
        <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               Opacity="0.7"
               IsHitTestVisible="False"/>

        <!-- All views render here -->
        <ContentControl x:Name="MainContent" Background="Transparent"/>

        <!-- Custom caption buttons (top-right, always on top) -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Height="32"
                    WindowChrome.IsHitTestVisibleInChrome="True">

            <!-- Minimize -->
            <Button x:Name="MinBtn" Width="46" Height="32"
                    Click="MinBtn_Click"
                    ToolTip="Minimize"
                    BorderThickness="0" Background="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Maximize / Restore -->
            <Button x:Name="MaxBtn" Width="46" Height="32"
                    Click="MaxBtn_Click"
                    BorderThickness="0" Background="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <TextBlock x:Name="icon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Close -->
            <Button x:Name="CloseBtn" Width="46" Height="32"
                    Click="CloseBtn_Click"
                    ToolTip="Close"
                    BorderThickness="0" Background="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#A32215"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
